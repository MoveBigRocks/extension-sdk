{
  "schemaVersion": 1,
  "slug": "sample-ops-extension",
  "name": "Sample Ops Extension",
  "version": "0.1.0",
  "publisher": "Your Company",
  "kind": "product",
  "scope": "workspace",
  "risk": "standard",
  "runtimeClass": "bundle",
  "description": "A minimal Move Big Rocks extension template for private custom extensions.",
  "workspacePlan": {
    "mode": "attach_to_existing_workspace"
  },
  "permissions": [
    "case:read",
    "case:write",
    "form:read",
    "form:write"
  ],
  "adminNavigation": [
    {
      "name": "sample-ops-dashboard",
      "section": "Extensions",
      "title": "Sample Ops Extension",
      "icon": "blocks",
      "endpoint": "sample-ops-admin-dashboard",
      "activePage": "sample-ops-extension"
    }
  ],
  "endpoints": [
    {
      "name": "sample-ops-admin-dashboard",
      "class": "admin_page",
      "mountPath": "/extensions/sample-ops-extension",
      "methods": [
        "GET",
        "HEAD"
      ],
      "auth": "session",
      "workspaceBinding": "workspace_from_session",
      "assetPath": "admin/dashboard.html"
    },
    {
      "name": "sample-ops-public-home",
      "class": "public_page",
      "mountPath": "/sample-ops-extension",
      "methods": [
        "GET",
        "HEAD"
      ],
      "auth": "public",
      "assetPath": "public/index.html"
    }
  ],
  "commands": [
    {
      "name": "sample-ops-extension.open-dashboard",
      "description": "Open the extension dashboard and verify the basic extension state."
    }
  ],
  "agentSkills": [
    {
      "name": "operate-sample-ops-extension",
      "description": "Review the extension, validate it, and monitor it after activation.",
      "assetPath": "agent-skills/operate-extension.md"
    }
  ],
  "customizableAssets": [
    "admin/dashboard.html",
    "public/index.html"
  ],
  "defaultConfig": {
    "branding": {
      "headline": "Sample Ops Extension"
    }
  }
}
